Port the brcmfmac-nexmon DKMS driver to kernel 6.13–6.18.

The Kali brcmfmac-nexmon-dkms source (PACKAGE_VERSION 6.12.2) targets the
6.6.y→6.12 kernel API. On newer Raspberry Pi OS kernels (the flint RPi 3B+
image ships 6.18.x) the DKMS build fails against two API changes:

  1. cfg80211_ops signature changes (kernel 6.13+): set_wiphy_params,
     set_tx_power and get_tx_power gained an `int radio_idx` (and, for
     get_tx_power, an `unsigned int link_id`) parameter for multi-radio wiphy
     support. Assigning the old-signature callbacks trips
     -Werror=incompatible-pointer-types.

  2. Legacy timer API rename (kernel 6.16+): del_timer_sync() →
     timer_delete_sync() and from_timer() → timer_container_of(). Used by
     cfg80211.c, btcoex.c and sdio.c.

  3. SDIO_DEVICE_ID_BROADCOM_CYPRESS_43752 was dropped from the RPi kernel's
     linux/mmc/sdio_ids.h; define it locally (mainline value 0xaae8).

Every change is guarded by LINUX_VERSION_CODE so the original kernel-6.12
build is unaffected. The version boundaries (6.13 for the cfg80211 ops, 6.16
for the timer rename) separate the two supported kernels (6.12 and 6.18) and
were validated with a clean DKMS build on 6.18.34+rpt-rpi-v8 (aarch64).
Intermediate kernels (6.13–6.17) are untested; adjust the boundary if needed.

Apply with:  patch -p1 -d /usr/src/brcmfmac-nexmon-<ver>  < kernel-6.18-porting.patch

--- a/cfg80211.c
+++ b/cfg80211.c
@@ -9,6 +9,15 @@

 #include <linux/kernel.h>
 #include <linux/version.h>
+/* nexmon 6.18 port: kernel 6.16 renamed the legacy timer API. */
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 16, 0)
+#ifndef del_timer_sync
+#define del_timer_sync(t) timer_delete_sync(t)
+#endif
+#ifndef from_timer
+#define from_timer(var, cbt, field) timer_container_of(var, cbt, field)
+#endif
+#endif
 #include <linux/etherdevice.h>
 #include <linux/module.h>
 #include <linux/vmalloc.h>
@@ -1317,7 +1326,11 @@
 	return err;
 }

-static s32 brcmf_cfg80211_set_wiphy_params(struct wiphy *wiphy, u32 changed)
+static s32 brcmf_cfg80211_set_wiphy_params(struct wiphy *wiphy,
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 13, 0)
+					   int radio_idx,
+#endif
+					   u32 changed)
 {
 	struct brcmf_cfg80211_info *cfg = wiphy_to_cfg(wiphy);
 	struct net_device *ndev = cfg_to_ndev(cfg);
@@ -2325,6 +2338,9 @@

 static s32
 brcmf_cfg80211_set_tx_power(struct wiphy *wiphy, struct wireless_dev *wdev,
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 13, 0)
+			    int radio_idx,
+#endif
 			    enum nl80211_tx_power_setting type, s32 mbm)
 {
 	struct brcmf_cfg80211_info *cfg = wiphy_to_cfg(wiphy);
@@ -2376,6 +2392,9 @@

 static s32
 brcmf_cfg80211_get_tx_power(struct wiphy *wiphy, struct wireless_dev *wdev,
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 13, 0)
+			    int radio_idx, unsigned int link_id,
+#endif
 			    s32 *dbm)
 {
 	struct brcmf_cfg80211_info *cfg = wiphy_to_cfg(wiphy);
